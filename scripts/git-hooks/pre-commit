#!/bin/bash
# Pre-commit hook: 機微情報の混入を機械的に検出
#
# このファイルはリポジトリで管理される「正本」。
# 各 clone でアクティブにするには:
#   bash scripts/install-hooks.sh
# を実行して .git/hooks/pre-commit に symlink を張る。
#
# Check 1: Identity leak (本リポジトリ固有)
#   検知対象パターンはハードコードせず hex escape 経由で組み立てる。
#   ファイル静的閲覧 (GitHub の blob 表示など) で識別文字列が grep ヒット
#   しないようにするための措置。Public 化後の filter-repo を 3 回踏んだ
#   経緯から、検知対象自身がリーク源にならないようにする。
# Check 2: gitleaks v8 (汎用機微情報スキャン)
# Check 3: secretlint (補完。gitleaks と別ルールセットで二重化)
# Check 4: 簡易 regex (gitleaks 未インストール時の fallback)
set -e

# ─────────────────────────────────────────────────────────────
# Check 1: Identity leak
# ─────────────────────────────────────────────────────────────
# 検知対象パターンを source 上に literal で書かないため hex escape で構築。
# bash の $'...' は ANSI-C quoting で \xNN を該当バイトに展開する。
# \\. は regex メタの literal dot ('\.') を表現するため二重エスケープ。
_P1=$'\x74-\x61ndo'           # → Linux user 名
_P2=$'\x74akao\\.\x61ndoh'    # → 個人メールローカル部 (regex: literal dot)
IDENTITY_PATTERN="(${_P1}|${_P2})"
# 本ポリシーを定義しているファイル自身は除外 (構築後の pattern が含まれる
# 可能性は無いが defense in depth で残置)。
POLICY_FILES_RE='^scripts/git-hooks/(pre-commit|commit-msg)$'
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR || true)
identity_found=0
if [[ -n "$STAGED_FILES" ]]; then
  while IFS= read -r f; do
    [[ -z "$f" || ! -f "$f" ]] && continue
    [[ "$f" =~ $POLICY_FILES_RE ]] && continue
    if grep -IqE "$IDENTITY_PATTERN" "$f" 2>/dev/null; then
      if [[ $identity_found -eq 0 ]]; then
        echo "ERROR: 個人識別情報が混入しています:" >&2
        identity_found=1
      fi
      grep -InE "$IDENTITY_PATTERN" "$f" 2>/dev/null | head -3 | sed "s|^|  $f:|" >&2
    fi
  done <<<"$STAGED_FILES"
fi
if [[ $identity_found -eq 1 ]]; then
  echo "" >&2
  echo "  対処: 個人識別子をマスクしてください (詳細は本 hook の _P1/_P2 を参照)。" >&2
  echo "  バイパス (非推奨): git commit --no-verify" >&2
  exit 1
fi

# ─────────────────────────────────────────────────────────────
# Check 2: gitleaks (機微情報全般)
# ─────────────────────────────────────────────────────────────
if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks git --pre-commit --staged --redact --no-banner 2>&1; then
    echo "" >&2
    echo "ERROR: gitleaks が機微情報の混入を検出しました。" >&2
    echo "  対処: 該当箇所を除去するか、誤検出なら .gitleaksignore で allowlist 化。" >&2
    echo "  バイパス (非推奨): git commit --no-verify" >&2
    exit 1
  fi
else
  echo "WARN: gitleaks がインストールされていません、簡易 regex に fallback します。" >&2
  echo "  推奨: https://github.com/gitleaks/gitleaks" >&2

  PATTERN_KV='(api[_-]?key|password|passwd|token|secret|bearer)[[:space:]]*[:=][[:space:]]*["'\''[:space:]]*[A-Za-z0-9+/=_-]{16,}'
  PATTERN_WEBHOOK='https?://[^[:space:]"]*/api/webhooks/[0-9]+/[A-Za-z0-9_-]{20,}'
  STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -vE '^\.env\.example$|^docs/|^\.git/hooks/|^scripts/git-hooks/' || true)
  found=0
  while IFS= read -r f; do
    if [[ -f "$f" ]] && grep -qE "$PATTERN_KV|$PATTERN_WEBHOOK" "$f" 2>/dev/null; then
      echo "ERROR: 機微情報らしき内容: $f" >&2
      grep -nE "$PATTERN_KV|$PATTERN_WEBHOOK" "$f" 2>/dev/null | head -3 | sed 's/^/      /' >&2
      found=1
    fi
  done <<<"$STAGED"
  if [[ $found -eq 1 ]]; then
    echo "" >&2
    echo "  対処: 機微情報を除去するか .gitignore で除外してください。" >&2
    echo "  バイパス: git commit --no-verify" >&2
    exit 1
  fi
fi

# ─────────────────────────────────────────────────────────────
# Check 3: secretlint (gitleaks と異なるルールセットで二重化)
# ─────────────────────────────────────────────────────────────
# Node.js 製。`npm install` 済みなら node_modules/.bin に展開される。
# 未インストール時は skip (Check 1/2 で最低限の網は張れている)。
REPO_ROOT="$(git rev-parse --show-toplevel)"
SECRETLINT_BIN="$REPO_ROOT/node_modules/.bin/secretlint"
if [[ -x "$SECRETLINT_BIN" ]]; then
  # staged ファイルのみを対象。削除/リネーム元は対象外、binary 等は secretlint が無視。
  # ファイル名に NUL や改行が含まれる前提はインフラリポジトリでは不要 (簡素化を優先)。
  mapfile -t STAGED_FOR_LINT < <(
    git diff --cached --name-only --diff-filter=ACMR | while IFS= read -r f; do
      [[ -f "$f" ]] && printf '%s\n' "$f"
    done
  )
  if (( ${#STAGED_FOR_LINT[@]} > 0 )); then
    if ! "$SECRETLINT_BIN" --secretlintignore "$REPO_ROOT/.gitignore" \
        "${STAGED_FOR_LINT[@]}"; then
      echo "" >&2
      echo "ERROR: secretlint が機微情報の混入を検出しました。" >&2
      echo "  対処: 該当箇所を除去するか .secretlintrc.json で allowlist 化。" >&2
      echo "  バイパス (非推奨): git commit --no-verify" >&2
      exit 1
    fi
  fi
else
  echo "INFO: secretlint 未導入のためスキップ (npm install で有効化)。" >&2
fi

exit 0
