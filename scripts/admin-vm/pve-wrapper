#!/usr/bin/env bash
# SSH wrapper for PVE-only commands (pct, qm, pvesh, pveum, ...).
# Invoked via symlinks named after the wrapped command (pct, qm, ...).
# Override target with PVE_HOST=user@host (default root@192.168.11.11).

set -euo pipefail

PVE_HOST=${PVE_HOST:-root@192.168.11.11}
cmd=$(basename "$0")

quoted=""
for arg in "$@"; do
  quoted+=" $(printf '%q' "$arg")"
done

ssh_opts=()
if [ -t 0 ] && [ -t 1 ]; then
  ssh_opts+=(-t)
fi

exec ssh "${ssh_opts[@]}" "$PVE_HOST" "$cmd$quoted"
