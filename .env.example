# =============================================
# Homelab infra .env template
# =============================================
# このファイルは .gitignore で除外されない（テンプレート用）。
# 実値が入る .env は絶対に commit しないこと。
# 値は cp .env.example .env してから実値を埋める。

# --- Cloudflare ---
export CF_API_TOKEN=<your-cf-api-token>
export CF_DNS_API_TOKEN=<your-cf-dns-api-token>
export CF_ACCOUNT_ID=<your-cf-account-id>
export CF_ZONE_ID=<your-zone-id>

# --- Cloudflare Tunnel (Puter 用、共有) ---
export CF_TUNNEL_TOKEN=<remote-managed-tunnel-token>
export CF_TUNNEL_ID=<tunnel-uuid>

# --- Cloudflare Access (Puter) ---
export CF_ACCESS_INCLUDE_EMAIL_DOMAINS=example.com,example.org
export CF_ACCESS_INCLUDE_EMAILS=

# --- Puter ---
export PUTER_DOMAIN=puter.example.com
export PROTECT_PUTER_SITE_DOMAIN=0

# --- Zabbix ---
# Zabbix API 永続トークン。MFA(TOTP) 有効環境では user.login が即 session
# invalidate するため、API token 必須。
# 発行手順: Zabbix UI → ユーザー → API トークン → 作成 → User=Admin, 期限なし。
# scripts/proxmox-zabbix-*.sh が ZBX_API_TOKEN を優先 read する。
export ZBX_API_TOKEN=<your-zabbix-api-token>
